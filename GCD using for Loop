import java.util.*;
class Main
{
    public static void main(String[] args)
    {
        Scanner in=new Scanner(System.in);
        
        int a=in.nextInt();
        int b=in.nextInt();
        
        int result=0;
        int min=Math.min(a,b);
        
        for(int i=2;i<=min;i++)
        {
            if(a%i==0 && b%i==0)
            {
                result=i;
            }
        }
        System.out.println(result);
    }
}
