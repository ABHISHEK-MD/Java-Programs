import java.util.*;
class Main
{
    public static int gcd(int a,int b)
    {
        if(b==0)
        {
            return a;
        }
        else
        {
            return gcd(b,a%b);
        }
    }
    
    public static int lcm(int a,int b)
    {
        return (a*b)/gcd(a,b);
    }

    public static void main(String[] args)
    {
        Scanner in=new Scanner(System.in);
        int a=in.nextInt();
        int b=in.nextInt();
        int c=in.nextInt();
        
        int lcm_a=lcm(a,b);
        int result=lcm(lcm_a,c);
        
        System.out.println(result);
    }
}
