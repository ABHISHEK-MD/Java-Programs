import java.util.*;
class Innings
{
    private String battingTeam;
    private long runs;
    
    public Innings(String battingTeam, long runs)
    {
        this.battingTeam=battingTeam;
        this.runs=runs;
    }
    
    public Innings()
    {
        this.battingTeam="";
        this.runs=0L;
    }
    
    public void setBattingTeam(String battingTeam)
    {
        this.battingTeam=battingTeam;
    }
    public void setRuns(long runs)
    {
        this.runs=runs;
    }
    
    public String getBattingTeam()
    {
        return battingTeam;
    }
    
    public long getRuns()
    {
        return runs;
    }
}

class Main
{
    public static void main(String[] agrs)
    {
        Scanner in=new Scanner(System.in);
        
        Innings[] innings = new Innings[2];
        
        for(int i=0;i<innings.length;i++)
        {
            String team  = in.next();
            long runs = in.nextLong();
            
            
            innings[i]=new Innings(team,runs);
        }
        
        for(int i=0;i<innings.length;i++)
        {
            System.out.println("Innings " + (i+1) + " Details");
            System.out.println("BattingTeam : " + innings[i].getBattingTeam());
            System.out.println("Runs scored : " + innings[i].getRuns());
        }
    }
}
