import java.util.*;
public class Main
{
	public static void main(String[] args) 
	{
	    Scanner in=new Scanner(System.in);
	    int n=in.nextInt();
        
        for(int i=1;i<=n;i++)
        {
            for(char j='A';j<'A'+i;j++)
            {
                System.out.print(j+" ");
            }
            System.out.println();
        }
	}
}
