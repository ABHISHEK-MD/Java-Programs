import java.util.*;
class Main
{
    public static int find(int n)
    {
        if(n==0 || n==1)
        {
            return 1;
        }
        return find(n-1)+find(n-2);
    }
    public static void main(String[] args)
    {
        Scanner in=new Scanner(System.in);
        
        int n=in.nextInt();
        
        System.out.println(find(n));
    }
}
