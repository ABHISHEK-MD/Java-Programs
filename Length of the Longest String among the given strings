import java.util.*;
class Main
{
    public static void main(String[] args)
    {
        Scanner in = new Scanner(System.in);
        
        int n=in.nextInt();
        in.nextLine();
        
        int maxLen=0;
        String longest="";
        for(int i=0;i<n;i++)
        {
            String word = in.nextLine();
            if(word.length()>maxLen)
            {
                maxLen=word.length();
                longest=word;
            }
        }
        
        System.out.println(longest.length());
        
    }
}
