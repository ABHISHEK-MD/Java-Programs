import java.util.*;
class Main
{
    public static int power(int x,int y)
    {
        if(y==0)
        {
            return 1;
        }
        return x*power(x,y-1);
    }
    
    public static void main(String[] args)
    {
        Scanner in=new Scanner(System.in);
        
        int x=in.nextInt();
        int y=in.nextInt();
        
        System.out.println(power(x,y));
    }
}
